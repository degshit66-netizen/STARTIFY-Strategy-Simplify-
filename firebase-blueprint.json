{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "name", "role"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Company/Tenant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "logo": { "type": "string" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["name", "ownerId"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Accounting journal entry",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "date": { "type": "string" },
        "payor": { "type": "string" },
        "particulars": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "tenantId": { "type": "string" }
      },
      "required": ["type", "date", "payor", "particulars", "amount", "status", "tenantId"]
    },
    "Configuration": {
      "title": "Configuration",
      "description": "Global system configurations",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "Form2307": {
      "title": "Form 2307",
      "description": "BIR Form 2307 (Certificate of Creditable Tax Withheld at Source)",
      "type": "object",
      "properties": {
        "payeeTin": { "type": "string" },
        "payeeName": { "type": "string" },
        "payorTin": { "type": "string" },
        "payorName": { "type": "string" },
        "periodFrom": { "type": "string" },
        "periodTo": { "type": "string" },
        "transactions": { "type": "string" },
        "status": { "type": "string" },
        "tenantId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["payeeTin", "payeeName", "payorTin", "payorName", "tenantId"]
    }
  },
  "firestore": {
    "configurations/{configId}": {
      "schema": { "$ref": "#/entities/Configuration" },
      "description": "Stores global system configurations"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "tenants/{tenantId}": {
      "schema": { "$ref": "#/entities/Tenant" },
      "description": "Stores company tenants"
    },
    "tenants/{tenantId}/ledger/{entryId}": {
      "schema": { "$ref": "#/entities/LedgerEntry" },
      "description": "Stores accounting entries for a tenant"
    },
    "tenants/{tenantId}/forms2307/{formId}": {
      "schema": { "$ref": "#/entities/Form2307" },
      "description": "Stores generated or imported Form 2307 records"
    }
  }
}
